{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beateros.dev/contracts/payment_mandate.schema.json",
  "title": "PaymentMandate",
  "description": "Bounded economic authority. final.md section 12.7. No payment without a mandate; no silent mandate expansion; all payment attempts produce receipts.",
  "type": "object",
  "required": [
    "mandate_id",
    "issuer",
    "holder",
    "session_id",
    "rail",
    "asset",
    "max_amount",
    "counterparty_policy",
    "purpose",
    "expires_at",
    "approval_threshold",
    "idempotency_key",
    "receipt_requirement"
  ],
  "properties": {
    "mandate_id": { "$ref": "common.schema.json#/$defs/Id" },
    "issuer": { "$ref": "common.schema.json#/$defs/Id" },
    "holder": { "$ref": "common.schema.json#/$defs/Id" },
    "session_id": { "$ref": "common.schema.json#/$defs/Id" },
    "rail": {
      "type": "string",
      "minLength": 1,
      "description": "Payment rail identifier (e.g. 'fake', 'ach', 'stablecoin:usdc'). Early phases use a fake rail only."
    },
    "asset": { "type": "string", "minLength": 1 },
    "max_amount": {
      "type": "object",
      "description": "Ceiling in minor units to avoid floating-point money.",
      "required": ["minor_units", "currency"],
      "properties": {
        "minor_units": { "type": "integer", "minimum": 0 },
        "currency": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "counterparty_policy": {
      "type": "string",
      "minLength": 1,
      "description": "Named policy restricting allowed counterparties."
    },
    "purpose": { "type": "string", "minLength": 1 },
    "expires_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
    "approval_threshold": {
      "type": "object",
      "description": "Above this amount, human/multi-party approval is required before spend.",
      "required": ["minor_units"],
      "properties": {
        "minor_units": { "type": "integer", "minimum": 0 },
        "mode": { "$ref": "common.schema.json#/$defs/ApprovalMode" }
      },
      "additionalProperties": true
    },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "receipt_requirement": {
      "type": "boolean",
      "description": "Must be true: all payment attempts produce receipts (final.md 12.7 invariant)."
    }
  },
  "additionalProperties": true
}
