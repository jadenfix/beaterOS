{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capability-receipt.schema.json",
  "title": "CapabilityReceipt",
  "description": "Append-only, hash-linked record of an executed action. final.md §7.6, §12.5, §13.11.",
  "type": "object",
  "additionalProperties": false,
  "required": ["receipt_id", "seq", "action_id", "tool_id", "target", "started_at", "finished_at", "status", "input_digest", "output_digest", "side_effect_summary", "prev_receipt_hash", "receipt_hash"],
  "properties": {
    "receipt_id": { "type": "string", "minLength": 1 },
    "seq": { "$ref": "common.schema.json#/$defs/uint" },
    "action_id": { "type": "string" },
    "tool_id": { "type": "string" },
    "target": { "$ref": "common.schema.json#/$defs/capability_selector" },
    "started_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "finished_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "status": { "type": "string" },
    "input_digest": { "type": "string" },
    "output_digest": { "type": "string" },
    "side_effect_summary": { "type": "string" },
    "side_effects": { "type": "array", "items": { "$ref": "common.schema.json#/$defs/side_effect_class" } },
    "external_ids": { "type": "array", "items": { "type": "string" } },
    "artifact_refs": { "type": "array", "items": { "type": "string" } },
    "payment_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_hash", "mandate_id", "rail", "adapter_id", "asset", "amount_minor_units", "counterparty_ref", "counterparty_binding_hash", "purpose", "payment_idempotency_key", "envelope_format", "envelope_hash", "rail_receipt_hash", "settlement_status"],
      "properties": {
        "manifest_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "mandate_id": { "type": "string", "minLength": 1 },
        "rail": { "type": "string", "minLength": 1 },
        "adapter_id": { "type": "string", "minLength": 1 },
        "adapter_version": { "type": "string", "minLength": 1 },
        "asset": { "type": "string", "minLength": 1 },
        "amount_minor_units": { "$ref": "common.schema.json#/$defs/uint" },
        "counterparty_ref": { "type": "string", "minLength": 1 },
        "counterparty_binding_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "purpose": { "type": "string", "minLength": 1 },
        "payment_idempotency_key": { "type": "string", "minLength": 1 },
        "envelope_format": { "type": "string", "minLength": 1 },
        "envelope_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "rail_receipt_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "settlement_status": { "enum": ["submitted", "settled", "failed", "canceled"] },
        "settled_at": { "$ref": "common.schema.json#/$defs/timestamp" }
      }
    },
    "prev_receipt_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "receipt_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
