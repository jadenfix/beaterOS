{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capability-receipt.schema.json",
  "title": "CapabilityReceipt",
  "description": "final.md 12.5 / contracts.rs (receipt.rs) CapabilityReceipt. Records what happened as a hash-chained, append-only ledger entry. Invariants: receipts are append-only; seq increases by one from zero; prev_receipt_hash links to the previous receipt (or GENESIS_HASH at seq 0); large artifacts are content-addressed via refs; sensitive fields can be redacted through references without breaking the chain. Note: final.md 12.5 names the link field 'previous_receipt_hash'; the wire format uses 'prev_receipt_hash' and adds 'seq'.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "seq",
    "action_id",
    "tool_id",
    "target",
    "started_at",
    "finished_at",
    "status",
    "input_digest",
    "output_digest",
    "side_effect_summary",
    "prev_receipt_hash",
    "receipt_hash"
  ],
  "properties": {
    "receipt_id": { "$ref": "common.schema.json#/$defs/Identifier" },
    "seq": { "type": "integer", "minimum": 0 },
    "action_id": { "$ref": "common.schema.json#/$defs/Identifier" },
    "tool_id": { "$ref": "common.schema.json#/$defs/Identifier" },
    "target": { "$ref": "common.schema.json#/$defs/CapabilitySelector" },
    "started_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
    "finished_at": { "$ref": "common.schema.json#/$defs/Timestamp" },
    "status": { "type": "string", "minLength": 1 },
    "input_digest": { "type": "string", "minLength": 1 },
    "output_digest": { "type": "string", "minLength": 1 },
    "side_effect_summary": { "type": "string" },
    "side_effects": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/SideEffectClass" }
    },
    "external_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifact_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "payment_receipt": {
      "description": "Typed payment-rail receipt evidence required when a PaymentMandate has receipt_requirement=required.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_hash",
        "mandate_id",
        "rail",
        "adapter_id",
        "asset",
        "amount_minor_units",
        "counterparty_ref",
        "counterparty_binding_hash",
        "purpose",
        "payment_idempotency_key",
        "envelope_format",
        "envelope_hash",
        "rail_receipt_hash",
        "settlement_status"
      ],
      "properties": {
        "manifest_hash": { "$ref": "common.schema.json#/$defs/HashValue" },
        "mandate_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "rail": { "type": "string", "minLength": 1 },
        "adapter_id": { "$ref": "common.schema.json#/$defs/Identifier" },
        "adapter_version": { "type": "string", "minLength": 1 },
        "asset": { "type": "string", "minLength": 1 },
        "amount_minor_units": { "$ref": "common.schema.json#/$defs/MinorUnits" },
        "counterparty_ref": { "type": "string", "minLength": 1 },
        "counterparty_binding_hash": { "$ref": "common.schema.json#/$defs/HashValue" },
        "purpose": { "type": "string", "minLength": 1 },
        "payment_idempotency_key": { "$ref": "common.schema.json#/$defs/Identifier" },
        "envelope_format": { "type": "string", "minLength": 1 },
        "envelope_hash": { "$ref": "common.schema.json#/$defs/HashValue" },
        "rail_receipt_hash": { "$ref": "common.schema.json#/$defs/HashValue" },
        "settlement_status": { "enum": ["submitted", "settled", "failed", "canceled"] },
        "settled_at": { "$ref": "common.schema.json#/$defs/Timestamp" }
      }
    },
    "prev_receipt_hash": { "$ref": "common.schema.json#/$defs/HashValue" },
    "receipt_hash": { "$ref": "common.schema.json#/$defs/HashValue" }
  }
}
